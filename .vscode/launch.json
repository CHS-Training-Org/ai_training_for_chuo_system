{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: server-side",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev",
      "cwd": "${workspaceFolder}/frontend"
    },
    {
      "name": "Next.js: client-side",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000"
    },
    {
      "name": "Next.js: full stack",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev",
      "cwd": "${workspaceFolder}/frontend",
      "serverReadyAction": {
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    },
    {
      "name": "Spring Boot: bookflow",
      "type": "java",
      "request": "launch",
      "mainClass": "com.example.bookflow.BookflowApplication",
      "projectName": "bookflow",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "DB_URL": "jdbc:postgresql://localhost:5432/bookflow",
        "DB_USERNAME": "bookflow",
        "DB_PASSWORD": "bookflow",
        "COGNITO_JWKS_URI": "http://localhost:9229/local_user_pool_id/.well-known/jwks.json"
      }
    }
  ]
}
