# バックエンド API URL（DevContainer 内では自動解決）
BACKEND_URL=http://localhost:8080

# Better Auth
BETTER_AUTH_SECRET=change-me-in-production
BETTER_AUTH_URL=http://localhost:3000
# クライアントサイドから参照する場合は NEXT_PUBLIC_ プレフィックスが必要
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Cognito Local（ローカル開発用）
#
# ⚠ ローカルではブラウザサインインは成立しない（既知の制約）:
#   Better Auth 1.6.11 の cognito プロバイダは authorize/token/JWKS を
#   https:// かつ AWS 実ドメインにハードコードしているため、
#   cognito-local（http://）への OAuth リダイレクトは動作しない（ADR-008 補足参照）。
#   ローカルの受入検証は scripts/provision-cognito.sh で JWT を取得して BE に直接渡す
#   API レベルで行う（Docs/plan/PHASE3_IMPL_TASKS.md § 8.1 参照）。
#
# provision-cognito.sh 実行後に出力される値を設定してください:
#   COGNITO_USER_POOL_ID: provision スクリプトが作成したプール ID（例: local_XXXXXXXX）
#   COGNITO_CLIENT_ID:    provision スクリプトが作成したクライアント ID
#
# backend の COGNITO_JWKS_URI は local_user_pool_id 固定（docker-compose.yml）。
# provision スクリプトが local_user_pool_id.json を自動同期するため変更不要。
#
COGNITO_USER_POOL_ID=local_XXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
COGNITO_CLIENT_SECRET=
# COGNITO_ISSUER: JWT 検証用 issuer（本番は https://cognito-idp.{region}.amazonaws.com/{poolId}）
COGNITO_ISSUER=http://localhost:9229/local_XXXXXXXX
# COGNITO_DOMAIN: Better Auth が認可リクエスト先として使う Cognito ホスト型 UI ドメイン
#   本番: "your-app.auth.ap-northeast-1.amazoncognito.com"
COGNITO_DOMAIN=localhost:9229
COGNITO_REGION=ap-northeast-1
