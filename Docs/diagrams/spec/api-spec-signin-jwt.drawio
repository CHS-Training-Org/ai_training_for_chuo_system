<mxfile>
  <diagram name="サインイン〜JWT検証">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ライフライン: ブラウザ -->
        <mxCell id="L1" value="ブラウザ" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;fillColor=#F8FAFC;strokeColor=#334155;fontColor=#1E293B;arcSize=8;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="150" height="700" as="geometry"/>
        </mxCell>

        <!-- ライフライン: Next.js (Better Auth) -->
        <mxCell id="L2" value="Next.js&#xa;(Better Auth)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;fillColor=#EFF6FF;strokeColor=#334155;fontColor=#1E293B;arcSize=8;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="40" width="170" height="700" as="geometry"/>
        </mxCell>

        <!-- ライフライン: AWS Cognito -->
        <mxCell id="L3" value="AWS Cognito" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;fillColor=#FEF2F2;strokeColor=#334155;fontColor=#1E293B;arcSize=8;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="40" width="150" height="700" as="geometry"/>
        </mxCell>

        <!-- ライフライン: Spring Boot (API) -->
        <mxCell id="L4" value="Spring Boot&#xa;(API)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;fillColor=#F0FDF4;strokeColor=#334155;fontColor=#1E293B;arcSize=8;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="690" y="40" width="170" height="700" as="geometry"/>
        </mxCell>

        <!-- M1: Browser→Next: POST /auth/signin {email, password}  y=160 (0.171) -->
        <mxCell id="M1" value="POST /auth/signin&#xa;{email, password}" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;strokeColor=#475569;fontColor=#1E293B;fontSize=10;exitX=1;exitY=0.171;exitDx=0;exitDy=0;entryX=0;entryY=0.171;entryDx=0;entryDy=0;" edge="1" source="L1" target="L2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- M2: Next→Cognito: AuthenticateUser (Cognito SDK)  y=220 (0.257) -->
        <mxCell id="M2" value="AuthenticateUser&#xa;(Cognito SDK)" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;strokeColor=#475569;fontColor=#1E293B;fontSize=10;exitX=1;exitY=0.257;exitDx=0;exitDy=0;entryX=0;entryY=0.257;entryDx=0;entryDy=0;" edge="1" source="L2" target="L3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- M3: Cognito→Next: JWT return (dashed)  y=275 (0.336) -->
        <mxCell id="M3" value="JWT (IdToken, AccessToken)" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;strokeColor=#999999;fontColor=#1E293B;fontSize=10;exitX=0;exitY=0.336;exitDx=0;exitDy=0;entryX=1;entryY=0.336;entryDx=0;entryDy=0;" edge="1" source="L3" target="L2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- M4: Next→Browser: Set-Cookie return (dashed)  y=330 (0.414) -->
        <mxCell id="M4" value="Set-Cookie: session=...&#xa;（セッション Cookie）" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;strokeColor=#999999;fontColor=#1E293B;fontSize=10;exitX=0;exitY=0.414;exitDx=0;exitDy=0;entryX=1;entryY=0.414;entryDx=0;entryDy=0;" edge="1" source="L2" target="L1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- M5: Browser→Next: GET / dashboard  y=420 (0.543) ※視覚的区切りに80px広げる -->
        <mxCell id="M5" value="GET /（ダッシュボード）" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;strokeColor=#475569;fontColor=#1E293B;fontSize=10;exitX=1;exitY=0.543;exitDx=0;exitDy=0;entryX=0;entryY=0.543;entryDx=0;entryDy=0;" edge="1" source="L1" target="L2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- M6: Next→Spring: GET /api/users/me with JWT  y=475 (0.621) -->
        <mxCell id="M6" value="GET /api/users/me&#xa;Authorization: Bearer &amp;lt;JWT&amp;gt;" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;strokeColor=#475569;fontColor=#1E293B;fontSize=10;exitX=1;exitY=0.621;exitDx=0;exitDy=0;entryX=0;entryY=0.621;entryDx=0;entryDy=0;" edge="1" source="L2" target="L4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- M7: Spring→Spring: JWT verify (自己メッセージ)  y_start=530 (0.700), y_end=580 (0.771) -->
        <mxCell id="M7" value="JWT 署名検証&#xa;custom:role クレーム取得" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;strokeColor=#475569;fontColor=#1E293B;fontSize=10;edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.700;exitDx=0;exitDy=0;entryX=1;entryY=0.771;entryDx=0;entryDy=0;" edge="1" source="L4" target="L4" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="910" y="530"/>
              <mxPoint x="910" y="580"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- M8: Spring→Next: 200 OK return (dashed)  y=630 (0.843) -->
        <mxCell id="M8" value="200 OK UserResponse" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;strokeColor=#999999;fontColor=#1E293B;fontSize=10;exitX=0;exitY=0.843;exitDx=0;exitDy=0;entryX=1;entryY=0.843;entryDx=0;entryDy=0;" edge="1" source="L4" target="L2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- M9: Next→Browser: ダッシュボード HTML (dashed)  y=685 (0.921) -->
        <mxCell id="M9" value="ダッシュボード HTML" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;strokeColor=#999999;fontColor=#1E293B;fontSize=10;exitX=0;exitY=0.921;exitDx=0;exitDy=0;entryX=1;entryY=0.921;entryDx=0;entryDy=0;" edge="1" source="L2" target="L1" parent="1">
